# Copy this file to .env and fill in your values for local development.
# In production (Docker/Arcane), set these as environment variables directly
# in your compose.yaml or the Arcane .env panel — do NOT commit a real .env file.

# Public URL used to generate the QR code on the TV display.
# Must be the full URL guests will use to reach the voting page.
BASE_URL=https://baby.yourdomain.com

# Secret segment in the admin URL: /admin-<ADMIN_SECRET>
# Change this to something only you know before deploying.
ADMIN_SECRET=babyshower2026

# (Docker only) Path on the host where database files are stored.
# Example for TrueNAS: /mnt/bubba/80_Apps/babynames/data
DATA_PATH=./data
