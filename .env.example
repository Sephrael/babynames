# Copy this file to .env and edit before deploying

# Public URL used for QR code generation
BASE_URL=https://baby.yourdomain.com

# Secret segment in admin URL: /admin-<ADMIN_SECRET>
ADMIN_SECRET=babyshower2026

# Path on TrueNAS host where database files are stored
# e.g. /mnt/tank/apps/babynames/data
DATA_PATH=./data
